## Agent Registry (ManagerAgent)

```python
class ManagerAgent:
    def __init__(self):
        self.agents: Dict[str, BaseWorkerAgent] = {}
        self._register_default_agents()
    
    def _register_default_agents(self):
        self.agents["financial_document"] = FinancialDocumentAgent()
        self.agents["sentiment"] = SentimentAnalysisAgent()
        self.agents["risk"] = RiskAssessmentAgent()
        # ... 11 more agents
        self.agents["research_planner"] = ResearchPlannerAgent()
    
    def register_agent(self, name: str, agent: BaseWorkerAgent):
        self.agents[name] = agent
    
    def get_agent(self, name: str) -> BaseWorkerAgent:
        return self.agents.get(name)
    
    async def check_health(self) -> Dict[str, AgentHealth]:
        # Checks all registered agents
```

