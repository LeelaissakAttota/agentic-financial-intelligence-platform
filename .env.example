# Financial Research Agent - Environment Configuration
# Copy this file to .env and fill in your values

# ==============================================================================
# LLM PROVIDER CONFIGURATION
# ==============================================================================
# LLM Provider: openrouter (required)
LLM_PROVIDER=openrouter

# OpenRouter API Key - REQUIRED
# Get your key from https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenRouter Base URL
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Model Configuration
# Primary model for complex tasks (financial analysis, risk, competitor, investment summary)
PRIMARY_MODEL=anthropic/claude-3.5-sonnet

# Fast model for simple tasks (news, sentiment, market data)
FAST_MODEL=anthropic/claude-3-haiku

# ==============================================================================
# DATABASE CONFIGURATION (PostgreSQL)
# ==============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=financial_research_agent
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ==============================================================================
# VECTOR DATABASE CONFIGURATION (ChromaDB)
# ==============================================================================
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION_NAME=financial_reports
CHROMA_PERSIST_DIR=./data/processed/chroma

# ==============================================================================
# RAG CONFIGURATION
# ==============================================================================
# Embedding model for document retrieval
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=32
EMBEDDING_INSTRUCTION="Represent this financial document for retrieval:"

# Document chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=50
MIN_CHUNK_SIZE=100

# Retrieval parameters
RETRIEVAL_TOP_K=20
RETRIEVAL_RERANK_TOP_K=10
RETRIEVAL_SCORE_THRESHOLD=0.5

# Reranker model
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_DEVICE=cpu
RERANKER_BATCH_SIZE=16

# Caching
EMBEDDING_CACHE_DIR=./data/processed/embedding_cache
EMBEDDING_CACHE_ENABLED=true

# ==============================================================================
# FILE PATHS
# ==============================================================================
REPORT_OUTPUT_DIR=./data/reports
LOG_LEVEL=INFO

# ==============================================================================
# OPTIONAL: ANTHROPIC DIRECT (if using Claude directly instead of OpenRouter)
# ==============================================================================
# ANTHROPIC_API_KEY=your_anthropic_api_key_here